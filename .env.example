# OpenAI API key (required)
OPENAI_API_KEY=sk-...

# Email notification settings
# For Gmail: use an App Password (Google Account > Security > 2-Step Verification > App passwords)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=you@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_RECIPIENT=you@gmail.com

# Shared API key — frontend must send this as X-API-Key header
# Generate with: openssl rand -hex 32
# Leave unset to run open (local dev only)
CHATBOT_API_KEY=

# CORS — comma-separated list of allowed origins for the API
# Use * for local dev; set to your personalweb URL in production
CORS_ORIGINS=*

# Profile — either set PROFILE_CONTENT (used in production / Azure App Service)
# or rely on profile.txt (used locally)
# PROFILE_CONTENT=My name is Stefan Kirov...

# Optional: path to local profile file (defaults to profile.txt)
# PROFILE_FILE=profile.txt
